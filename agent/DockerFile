# Use a slim Python 3.10 image as the base
FROM python:3.10-slim

# Install system dependencies required for packet manipulation and building wheels
RUN apt-get update && apt-get install -y \
    build-essential \
    iptables \
    libnetfilter-queue-dev \
    libffi-dev \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Set the working directory
WORKDIR /app

# Copy the requirements file and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the rest of the application code
COPY . .

# The container must run as root to modify iptables and attach to NFQUEUE.
# In docker-compose, this container must also have cap_add: - NET_ADMIN
CMD ["python", "main.py"]